  <entry>
    <title>20220524超级竞争下的战略:组织结构及控制10</title>
    <link href="https://wayne0163.github.io/2022/05/24/20220524%E8%B6%85%E7%BA%A7%E7%AB%9E%E4%BA%89%E4%B8%8B%E7%9A%84%E6%88%98%E7%95%A5%E2%80%94%E7%BB%84%E7%BB%87%E6%9E%B6%E6%9E%84%E4%B8%8E%E6%8E%A7%E5%88%B610/"/>
